# Imagora production environment template.
# Copy to your deployment secret store or platform environment UI, then replace every example value.
# Do not commit real values.

NODE_ENV=production
API_HOST=0.0.0.0
API_PORT=4100
WEB_ORIGIN=https://imagora.example.com
NEXT_PUBLIC_API_BASE_URL=/api

DATA_STORE=prisma
# 使用自带 docker-compose.prod.yml 的 postgres 服务时，只需填这三项，
# compose 会用它们拼出指向内部服务名 postgres:5432 的 DATABASE_URL。
POSTGRES_USER=imagora
POSTGRES_PASSWORD=replace-password
POSTGRES_DB=imagora
# 若改用外部托管数据库（不用自带 postgres 服务），直接设置完整 DATABASE_URL。
# compose 内部会以上面三项拼接覆盖此值；仅在脱离 compose 单独运行 api/worker 时才用到它。
DATABASE_URL=postgresql://imagora:replace-password@postgres.example.com:5432/imagora
POSTGRES_BACKUP_DIR=./backups/postgres

QUEUE_PROVIDER=bullmq
REDIS_URL=redis://redis.example.com:6379
RUNTIME_STATE_PROVIDER=redis
RUNTIME_STATE_KEY_PREFIX=imagora:runtime
RUNTIME_STATE_REDIS_CONNECT_TIMEOUT_MS=500
RUNTIME_STATE_REDIS_COMMAND_TIMEOUT_MS=500
GENERATION_QUEUE_COMMAND_TIMEOUT_MS=2000
GENERATION_ENQUEUE_RECONCILE_INTERVAL_MS=5000
GENERATION_ENQUEUE_RECONCILE_BATCH_SIZE=100
GENERATION_ENQUEUE_FAILURE_LOG_INTERVAL_MS=60000

IMAGE_PROVIDER_DEFAULT=openai
AI_PROVIDER=
IMAGE_MODEL_DEFAULT=openai:gpt-image-2
OPENAI_IMAGE_MODEL=
OPENAI_API_KEY=sk-live-replace-this
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TIMEOUT_MS=300000
OPENAI_MAX_RETRIES=1
GENERATION_PENDING_TIMEOUT_MS=1800000
GENERATION_RUNNING_TIMEOUT_MS=1800000
WORKER_SUPERVISOR_SHUTDOWN_TIMEOUT_MS=1860000
WORKER_STOP_GRACE_PERIOD=32m

STORAGE_PROVIDER=r2
S3_ENDPOINT=https://account-id.r2.cloudflarestorage.com
S3_REGION=auto
S3_BUCKET=imagora-production
S3_ACCESS_KEY_ID=replace-r2-access-key
S3_SECRET_ACCESS_KEY=replace-r2-secret-key
S3_PUBLIC_BASE_URL=https://images.imagora.example.com

PAYMENT_PROVIDER=stripe
NEXT_PUBLIC_PAYMENT_PROVIDER=stripe
STRIPE_SECRET_KEY=sk_live_replace_this
STRIPE_WEBHOOK_SECRET=whsec_replace_this
STRIPE_SUCCESS_URL=https://imagora.example.com/orders?paid=1
STRIPE_CANCEL_URL=https://imagora.example.com/pricing?canceled=1
STRIPE_TIMEOUT_MS=15000

MAILER_PROVIDER=smtp
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=replace-smtp-user
SMTP_PASSWORD=replace-smtp-password
SMTP_FROM=noreply@imagora.example.com

SAFETY_PROVIDER=http
SAFETY_TEXT_ENDPOINT=https://safety.example.com/text
SAFETY_IMAGE_ENDPOINT=https://safety.example.com/image
SAFETY_TIMEOUT_MS=15000

SESSION_COOKIE_NAME=imagora_session
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=Strict
REQUIRE_EMAIL_VERIFICATION=true

RATE_LIMIT_PROVIDER=redis
RATE_LIMIT_WINDOW_MS=60000
REDIS_RATE_LIMIT_TIMEOUT_MS=500

ORDER_PENDING_TTL_MINUTES=30
API_BODY_LIMIT_BYTES=102400

# 管理员退款单笔二次确认阈值（分），默认 50000
ADMIN_REFUND_CONFIRM_THRESHOLD_CENTS=50000

# 验证码：生产强制 turnstile（production-config 会校验）。到 Cloudflare 控制台申请一对 site/secret key。
CAPTCHA_PROVIDER=turnstile
TURNSTILE_SITE_KEY=0x4AAAAAAA-replace-site-key
TURNSTILE_SECRET_KEY=0x4AAAAAAA-replace-secret-key
TURNSTILE_TIMEOUT_MS=10000
LOCAL_STORAGE_DIR=./data/generated-images
LOCAL_STORAGE_PUBLIC_BASE_URL=http://127.0.0.1:4100/api/files/local-images
LOCAL_STORAGE_SIGNING_SECRET=replace-only-if-filesystem-storage-is-used

FEATURE_GENERATION_ENABLED=true
FEATURE_PAYMENTS_ENABLED=true
FEATURE_UPLOADS_ENABLED=true
FEATURE_DOWNLOADS_ENABLED=true

ALERT_GENERATION_FAILURE_RATE=0.35
ALERT_GENERATION_BACKLOG_MAX=25
ALERT_STALE_RUNNING_MINUTES=10
ALERT_STALE_RUNNING_TASKS_MAX=0
ALERT_PENDING_ORDERS_MAX=50
ALERT_PAYMENT_AMOUNT_MISMATCH_MAX=0
ALERT_HTTP_FAILURE_RATE=0.05
ALERT_WEBHOOK_URL=https://alerts.example.com/webhook
ALERT_WEBHOOK_TIMEOUT_MS=10000
ALERT_WEBHOOK_MAX_ATTEMPTS=3
ALERT_EMAIL_TO=ops@imagora.example.com
ALERT_COOLDOWN_MS=1800000
ALERT_EVALUATION_INTERVAL_MS=60000
ALERT_NOTIFICATION_RETENTION_MAX=100

# P0 gray-release signoff. Set these only after real external smoke/load checks pass.
P0_REQUIRE_EXTERNAL_SMOKE=1
P0_EXTERNAL_SMOKE_PASSED=0
P0_EXTERNAL_SMOKE_EVIDENCE=

{
  "name": "@imagora/worker",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/main.js",
  "scripts": {
    "dev": "npm --prefix ../.. run build:packages && tsx --env-file=../../.env src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node --env-file=../../.env dist/main.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@imagora/ai-providers": "0.1.0",
    "@imagora/database": "0.1.0",
    "@imagora/queue": "0.1.0",
    "@imagora/safety": "0.1.0",
    "@imagora/shared": "0.1.0",
    "@imagora/storage": "0.1.0",
    "pino": "^9.5.0",
    "pino-pretty": "12.1.0",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "tsx": "^4.23.0",
    "typescript": "^5.7.2"
  }
}

API_PORT=4100
API_HOST=127.0.0.1
WEB_ORIGIN=http://127.0.0.1:3100
CSRF_ALLOWED_ORIGINS=http://127.0.0.1:3100
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:4100
DATABASE_URL=postgresql://imagora:imagora@127.0.0.1:5432/imagora
REDIS_URL=redis://127.0.0.1:6379
RUNTIME_STATE_PROVIDER=memory
RUNTIME_STATE_KEY_PREFIX=imagora:runtime
RUNTIME_STATE_REDIS_CONNECT_TIMEOUT_MS=500
RUNTIME_STATE_REDIS_COMMAND_TIMEOUT_MS=500
IMAGORA_STORE_PATH=./data/imagora-store.json
IMAGORA_SEED_DEMO_DATA=false
IMAGORA_BOOTSTRAP_ADMIN_EMAIL=admin@imagora.local
IMAGORA_BOOTSTRAP_ADMIN_PASSWORD=ChangeMe123!
BACKUP_DIR=./backups
POSTGRES_BACKUP_DIR=./backups/postgres
WORKER_POLL_INTERVAL_MS=2500
# 生成任务超时（毫秒）。第三方 OpenAI 代理响应慢时可调大 RUNNING 超时，避免正常任务被误判失败。
GENERATION_PENDING_TIMEOUT_MS=1800000
GENERATION_RUNNING_TIMEOUT_MS=1800000
# supervisor 等待 worker 排空当前任务的上限；Compose 停止宽限必须略大于此值。
WORKER_SUPERVISOR_SHUTDOWN_TIMEOUT_MS=1860000
WORKER_STOP_GRACE_PERIOD=32m
DATA_STORE=prisma
QUEUE_PROVIDER=inline
GENERATION_QUEUE_COMMAND_TIMEOUT_MS=2000
GENERATION_ENQUEUE_RECONCILE_INTERVAL_MS=5000
GENERATION_ENQUEUE_RECONCILE_BATCH_SIZE=100
GENERATION_ENQUEUE_FAILURE_LOG_INTERVAL_MS=60000
IMAGE_PROVIDER_DEFAULT=
IMAGE_MODEL_DEFAULT=
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
# 存储驱动：inline(base64内联,仅开发) / filesystem(本地磁盘) / s3 / r2
STORAGE_PROVIDER=inline
# filesystem 模式：图片落地目录 + 签名密钥（务必改成随机值，否则可伪造签名越权读文件）
LOCAL_STORAGE_DIR=./data/generated-files
LOCAL_STORAGE_SIGNING_SECRET=change-me-to-a-random-secret
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=
PAYMENT_PROVIDER=mock
NEXT_PUBLIC_PAYMENT_PROVIDER=mock
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_WEBHOOK_TOLERANCE_SECONDS=300
STRIPE_SUCCESS_URL=http://127.0.0.1:3100/orders?paid=1
STRIPE_CANCEL_URL=http://127.0.0.1:3100/pricing?canceled=1
SAFETY_PROVIDER=local
ORDER_PENDING_TTL_MINUTES=30
# 管理员退款：单笔金额（分）达到该阈值时前端强制二次确认，默认 50000（¥500）
ADMIN_REFUND_CONFIRM_THRESHOLD_CENTS=50000
# 验证码提供方：builtin(内置 SVG 点选，可被脚本破解，仅开发/测试兜底) / turnstile(Cloudflare Turnstile)
CAPTCHA_PROVIDER=builtin
# Turnstile 密钥（CAPTCHA_PROVIDER=turnstile 时必填）。SITE_KEY 可公开下发给前端，SECRET_KEY 仅后端用
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
TURNSTILE_TIMEOUT_MS=10000
SESSION_COOKIE_NAME=imagora_session
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=Strict
DOWNLOAD_URL_TTL_MINUTES=15
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_PROVIDER=memory
REDIS_RATE_LIMIT_TIMEOUT_MS=500
API_BODY_LIMIT_BYTES=102400
OPENAI_TIMEOUT_MS=120000
STRIPE_TIMEOUT_MS=15000
S3_TIMEOUT_MS=30000
RATE_LIMIT_AUTH_MAX=20
RATE_LIMIT_GENERATION_MAX=30
RATE_LIMIT_UPLOAD_MAX=20
RATE_LIMIT_DOWNLOAD_MAX=60
UPLOAD_MAX_BYTES=5242880
UPLOAD_MAX_BASE64_CHARS=8000000
UPLOAD_MAX_DIMENSION=8192
UPLOAD_REFERENCE_TTL_DAYS=1
FEATURE_GENERATION_ENABLED=true
FEATURE_PAYMENTS_ENABLED=true
FEATURE_UPLOADS_ENABLED=true
FEATURE_DOWNLOADS_ENABLED=true
ALERT_GENERATION_FAILURE_RATE=0.35
ALERT_GENERATION_BACKLOG_MAX=25
ALERT_STALE_RUNNING_MINUTES=10
ALERT_STALE_RUNNING_TASKS_MAX=0
ALERT_PENDING_ORDERS_MAX=50
ALERT_PAYMENT_AMOUNT_MISMATCH_MAX=0
ALERT_HTTP_FAILURE_RATE=0.05
# 告警外发通道（生产环境必须至少配置一个：ALERT_WEBHOOK_URL 或 ALERT_EMAIL_TO）
# 通用 Webhook：POST 结构化 JSON 到目标地址，可对接自建告警网关 / Slack / 企业微信等
ALERT_WEBHOOK_URL=
ALERT_WEBHOOK_TIMEOUT_MS=10000
ALERT_WEBHOOK_MAX_ATTEMPTS=3
# 邮件告警收件人（逗号/分号分隔多个），复用 SMTP 邮件通道
ALERT_EMAIL_TO=
# 同一 (通道, 告警) 在冷却窗口内只发一次，跨窗口可再发（毫秒，默认 30 分钟）
ALERT_COOLDOWN_MS=1800000
# 后台主动评估告警并外发的间隔（毫秒，默认 60 秒；<=0 关闭）
ALERT_EVALUATION_INTERVAL_MS=60000
ALERT_NOTIFICATION_RETENTION_MAX=100

{
  "name": "@imagora/database",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "node scripts/prisma-cli.mjs generate-if-needed && tsc -p tsconfig.json",
    "typecheck": "node scripts/prisma-cli.mjs generate-if-needed && tsc -p tsconfig.json --noEmit",
    "prisma:validate": "node scripts/prisma-cli.mjs validate",
    "prisma:generate": "node scripts/prisma-cli.mjs generate",
    "prisma:push": "node scripts/prisma-cli.mjs db push",
    "prisma:migrate-deploy": "node scripts/prisma-cli.mjs migrate deploy",
    "prisma:migrate-dev": "node scripts/prisma-cli.mjs migrate dev",
    "prisma:migrate-reset": "node scripts/prisma-cli.mjs migrate reset --force"
  },
  "dependencies": {
    "@imagora/shared": "0.1.0",
    "@prisma/client": "^6.19.0",
    "prisma": "^6.19.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "typescript": "^5.7.2"
  }
}
